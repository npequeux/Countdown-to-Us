    private string _currentLang = "en";
    private System.Globalization.CultureInfo _currentCulture = System.Globalization.CultureInfo.CreateSpecificCulture("en-US");
    private string _lastBackgroundUrl = string.Empty;

    // Used by wallpaper generator
    private DateTime _currentTime = DateTime.Now;

    private string T(string key)
    {
        if (Translations.TryGetValue(_currentLang, out var dict) && dict.TryGetValue(key, out var val))
            return val;
        if (Translations.TryGetValue("en", out var enDict) && enDict.TryGetValue(key, out var fallback))
            return fallback;
        return key;
    }

    private string _targetDateStr = DefaultTargetDate;
    private DateTime _targetDate;
    private Timer? _countdownTimer;
    private Timer? _slideshowTimer;

    // Countdown values
    private int Years { get; set; }
    private int Months { get; set; }
    private int Days { get; set; }
    private int Hours { get; set; }
    private int Minutes { get; set; }
    private int Seconds { get; set; }
    private int TotalDays { get; set; }

    // Display strings
    private string CountdownTitle => $"{T("countdownTo")} {_targetDate.ToString("MMMM d, yyyy", _currentCulture)}";
    private string TargetDateDisplay => $"{T("targetDatePrefix")} {_targetDate.ToString("MMMM d, yyyy 'at' hh:mm:ss tt", _currentCulture)}";
    private string DaysBreakdown => $"{Years} {T("years")}, {Months} {T("months")}, {Days} {T("days")}";

    // Slideshow
    private List<string> _defaultImages = DefaultImages.OrderBy(_ => Random.Shared.Next()).ToList();
    private List<string> SlideshowImages { get; set; } = new();
    private int CurrentSlide { get; set; }
    private List<string> ActiveImages => SlideshowImages.Count > 0 ? SlideshowImages : _defaultImages;
    private string CurrentImageSrc => ActiveImages.Count > 0 ? ActiveImages[CurrentSlide] : string.Empty;

    // Settings panel
    private bool SettingsPanelOpen { get; set; }
    private DateTime TargetDateInputValue { get; set; }

    // Wallpaper
    private bool _autoWallpaper;
    private bool _wallpaperBusy;
    private string _wallpaperStatus = string.Empty;
    private Timer? _wallpaperTimer;
    private int _lastWallpaperMinute = -1;
    private int _lastWallpaperSecond = -1;
    private int _wallpaperIntervalSeconds = WallpaperIntervalEveryMinute;

    private const int WallpaperIntervalEveryMinute = 60;
    private const int WallpaperIntervalEverySecond = 1;

    // Cached background PNG (static portions without countdown numbers).
    // Invalidated whenever the displayed slideshow image changes.
    private byte[]? _cachedWallpaperBackground;
    private string _cachedWallpaperImageSrc = string.Empty;
    private bool _cachedWallpaperHasImage;

    protected override async Task OnInitializedAsync()
    {
        // Load persisted language
        var storedLang = await JS.InvokeAsync<string?>("localStorage.getItem", "language");
        if (!string.IsNullOrEmpty(storedLang) && Translations.ContainsKey(storedLang))
            _currentLang = storedLang;
        _currentCulture = CreateCulture(_currentLang);

        // Load persisted target date
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "targetDate");
        _targetDateStr = stored ?? DefaultTargetDate;
        _targetDate = DateTime.Parse(_targetDateStr);
        TargetDateInputValue = _targetDate;

        // Load persisted slideshow images
        var imagesJson = await JS.InvokeAsync<string?>("localStorage.getItem", "slideshowImages");
        if (!string.IsNullOrEmpty(imagesJson))
        {
            try
            {
                var images = System.Text.Json.JsonSerializer.Deserialize<List<string>>(imagesJson);
                if (images != null) SlideshowImages = images;
            }
            catch { /* ignore corrupt data */ }
        }

        UpdateCountdown();

        // Restore auto-wallpaper preference
        if (WallpaperService.IsSupported)
        {
            var autoWallStr = await JS.InvokeAsync<string?>("localStorage.getItem", "autoWallpaper");
            if (autoWallStr == "true")
            {
                _autoWallpaper = true;
                var intervalStr = await JS.InvokeAsync<string?>("localStorage.getItem", "wallpaperIntervalSeconds");
                if (int.TryParse(intervalStr, out var savedInterval) && (savedInterval == WallpaperIntervalEverySecond || savedInterval == WallpaperIntervalEveryMinute))
                    _wallpaperIntervalSeconds = savedInterval;
                StartWallpaperTimerIfNeeded();
            }
        }

        // Start 1-second countdown timer
        _countdownTimer = new Timer(1000);
        _countdownTimer.Elapsed += OnCountdownTick;
        _countdownTimer.AutoReset = true;
        _countdownTimer.Start();

        // Start slideshow timer if needed
        StartSlideshowTimerIfNeeded();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("setHtmlLang", T("locale").Split('-')[0]);
        var url = CurrentImageSrc;
        if (!string.IsNullOrEmpty(url) && url != _lastBackgroundUrl)
        {
            _lastBackgroundUrl = url;
            await JS.InvokeVoidAsync("setBodyBackground", url);
        }
    }

    private void OnCountdownTick(object? sender, ElapsedEventArgs e)
    {
        UpdateCountdown();
        InvokeAsync(UpdateCountdownDisplayAsync);
    }

    private async Task UpdateCountdownDisplayAsync()
    {
        await JS.InvokeVoidAsync("updateCountdownDisplay",
            TotalDays.ToString(),
            Hours.ToString("D2"),
            Minutes.ToString("D2"),
            Seconds.ToString("D2"),
            DaysBreakdown);
    }

    private void UpdateCountdown()
    {
        var now = DateTime.Now;
        _currentTime = now;
        var distance = _targetDate - now;

        if (distance <= TimeSpan.Zero)
        {
            Years = Months = Days = Hours = Minutes = Seconds = TotalDays = 0;
            return;
        }

        // Use the date corresponding to now + complete days remaining so that
        // the time-of-day component (hours/minutes/seconds) is fully captured by
        // distance.Hours/Minutes/Seconds and does not bleed into the days count.
        var startDate = now.Date;
        var endDate = startDate.AddDays(distance.Days);

        int years = endDate.Year - startDate.Year;
        int months = endDate.Month - startDate.Month;
        int days = endDate.Day - startDate.Day;

        if (days < 0)
        {
            months--;
            // Borrow from the month immediately before endDate
            int borrowYear = endDate.Month == 1 ? endDate.Year - 1 : endDate.Year;
            int borrowMonth = endDate.Month == 1 ? 12 : endDate.Month - 1;
            days += DateTime.DaysInMonth(borrowYear, borrowMonth);
        }
        if (months < 0)
        {
            years--;
            months += 12;
        }

        Years = years;
        Months = months;
        Days = days;
        Hours = distance.Hours;
        Minutes = distance.Minutes;
        Seconds = distance.Seconds;
        TotalDays = (int)distance.TotalDays;
    }

    private void ToggleSettings()
    {
        SettingsPanelOpen = !SettingsPanelOpen;
    }

    private async Task OnLanguageChanged()
    {
        _currentCulture = CreateCulture(_currentLang);
        _cachedWallpaperBackground = null;
        await JS.InvokeVoidAsync("localStorage.setItem", "language", _currentLang);
        await JS.InvokeVoidAsync("setHtmlLang", T("locale").Split('-')[0]);
    }

    private static System.Globalization.CultureInfo CreateCulture(string lang)
    {
        try
        {
            return Translations.TryGetValue(lang, out var dict) && dict.TryGetValue("locale", out var locale)
                ? System.Globalization.CultureInfo.CreateSpecificCulture(locale)
                : System.Globalization.CultureInfo.InvariantCulture;
        }
        catch
        {
            return System.Globalization.CultureInfo.InvariantCulture;
        }
    }

    private async Task ApplyDate()
    {
        if (TargetDateInputValue == default)
        {
            await JS.InvokeVoidAsync("alert", T("alertSelectDate"));
            return;
        }
        if (TargetDateInputValue <= DateTime.Now)
        {
            var ok = await JS.InvokeAsync<bool>("confirm", T("confirmPastDate"));
            if (!ok) return;
        }

        _targetDate = TargetDateInputValue;
        _targetDateStr = _targetDate.ToString("yyyy-MM-ddTHH:mm:ss");
        _cachedWallpaperBackground = null;
        await JS.InvokeVoidAsync("localStorage.setItem", "targetDate", _targetDateStr);
        UpdateCountdown();
    }

    private async Task HandlePhotoUpload(InputFileChangeEventArgs e)
    {
        var skipped = 0;
        foreach (var file in e.GetMultipleFiles(50))
        {
            try
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                var contentType = string.IsNullOrEmpty(file.ContentType) ? "image/jpeg" : file.ContentType;
                var dataUrl = $"data:{contentType};base64,{base64}";
                SlideshowImages.Add(dataUrl);
            }
            catch
            {
                skipped++;
            }
        }

        if (skipped > 0)
            await JS.InvokeVoidAsync("alert", T("alertSkippedPhotos"));

        CurrentSlide = 0;
        _cachedWallpaperBackground = null;
        StopSlideshowTimer();
        StartSlideshowTimerIfNeeded();
        await SaveSlideshowImages();
    }

    private async Task ClearPhotos()
    {
        SlideshowImages.Clear();
        CurrentSlide = 0;
        _cachedWallpaperBackground = null;
        StopSlideshowTimer();
        StartSlideshowTimerIfNeeded();
        await JS.InvokeVoidAsync("localStorage.removeItem", "slideshowImages");
    }

    private async Task SaveSlideshowImages()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(SlideshowImages);
            await JS.InvokeVoidAsync("localStorage.setItem", "slideshowImages", json);
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", T("alertStorageError"));
        }
    }

    private void StartSlideshowTimerIfNeeded()
    {
        if (ActiveImages.Count > 1 && _slideshowTimer == null)
        {
            _slideshowTimer = new Timer(SlideshowIntervalMs);
            _slideshowTimer.Elapsed += OnSlideshowTick;
            _slideshowTimer.AutoReset = true;
            _slideshowTimer.Start();
        }
    }

    private void StopSlideshowTimer()
    {
        _slideshowTimer?.Stop();
        _slideshowTimer?.Dispose();
        _slideshowTimer = null;
    }

    private void OnSlideshowTick(object? sender, ElapsedEventArgs e)
    {
        CurrentSlide = (CurrentSlide + 1) % ActiveImages.Count;
        InvokeAsync(StateHasChanged);
    }

    private void PrevSlide()
    {
        var active = ActiveImages;
        CurrentSlide = (CurrentSlide - 1 + active.Count) % active.Count;
        _cachedWallpaperBackground = null;
        StopSlideshowTimer();
        StartSlideshowTimerIfNeeded();
    }

    private void NextSlide()
    {
        var active = ActiveImages;
        CurrentSlide = (CurrentSlide + 1) % active.Count;
        _cachedWallpaperBackground = null;
        StopSlideshowTimer();
        StartSlideshowTimerIfNeeded();
    }

    // ─── Wallpaper ────────────────────────────────────────────────────────────

    /// <summary>
    /// Physical-pixel width threshold below which a display is considered a foldable
    /// cover screen.  The Samsung Galaxy Z Flip cover screen is ~260 px wide, while
    /// any normal phone display is at least 480 px wide, so 400 px is a safe boundary.
    /// </summary>
    private const int CoverScreenWidthThreshold = 400;

    /// <summary>
    /// Returns true when the active Android display is the small cover screen of a
    /// foldable device (e.g. Samsung Galaxy Z Flip).  The Z Flip cover screen is
    /// approximately 260 × 512 physical pixels, so <see cref="CoverScreenWidthThreshold"/>
    /// on the shorter side reliably distinguishes it from any normal phone display.
    /// On all other platforms this always returns false.
    /// </summary>
    private static bool IsCoverScreen()
    {
#if ANDROID
        var info = DeviceDisplay.Current.MainDisplayInfo;
        int width  = (int)info.Width;
        int height = (int)info.Height;
        int shorter = Math.Min(width, height);
        return shorter > 0 && shorter < CoverScreenWidthThreshold;
#else
        return false;
#endif
    }

    private async Task SetWallpaperNow()
    {
        if (_wallpaperBusy) return;

        // Do not update the wallpaper when running on the small cover screen of a
        // foldable (e.g. Samsung Galaxy Z Flip). Wallpaper changes should only apply
        // to the main (inner) display.
        if (IsCoverScreen()) return;
        _wallpaperBusy = true;
        _wallpaperStatus = string.Empty;
        StateHasChanged();
        try
        {
            var (wpWidth, wpHeight) = GetWallpaperDimensions();
            var currentSrc = CurrentImageSrc;

            // Invalidate the cached background whenever the slideshow image changes.
            if (currentSrc != _cachedWallpaperImageSrc)
            {
                _cachedWallpaperBackground = null;
                _cachedWallpaperImageSrc   = currentSrc;
            }

            byte[] png;
            if (_cachedWallpaperBackground != null)
            {
                // Fast path: composite only the countdown numbers onto the cached background.
                var data = BuildWallpaperData(_cachedWallpaperHasImage ? new byte[] { 0 } : null);
                png = Services.WallpaperGenerator.UpdateCountdownPng(
                    _cachedWallpaperBackground, data, wpWidth, wpHeight);
            }
            else
            {
                // Full render: decode background image, draw card, then countdown.
                var imageBytes = await GetCurrentImageBytes();
                _cachedWallpaperHasImage = imageBytes is { Length: > 0 };
                var data = BuildWallpaperData(imageBytes);
                _cachedWallpaperBackground = Services.WallpaperGenerator.GenerateBackground(data, wpWidth, wpHeight);
                png = Services.WallpaperGenerator.UpdateCountdownPng(
                    _cachedWallpaperBackground, data, wpWidth, wpHeight);
            }

            await WallpaperService.SetWallpaperAsync(png);
            _wallpaperStatus = T("wallpaperSet");
        }
        catch (Exception ex)
        {
            // Surface a user-friendly message while capturing details for debug builds.
            System.Diagnostics.Debug.WriteLine($"[WallpaperService] SetWallpaperAsync failed: {ex}");
            _wallpaperStatus = T("wallpaperError");
        }
        finally
        {
            _wallpaperBusy = false;
        }
        StateHasChanged();
    }

    private async Task OnAutoWallpaperChanged()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "autoWallpaper", _autoWallpaper ? "true" : "false");
        if (_autoWallpaper)
            StartWallpaperTimerIfNeeded();
        else
            StopWallpaperTimer();
    }

    private async Task OnWallpaperIntervalChanged()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "wallpaperIntervalSeconds", _wallpaperIntervalSeconds.ToString());
        // Restart the timer with the new interval.
        StopWallpaperTimer();
        if (_autoWallpaper)
            StartWallpaperTimerIfNeeded();
    }

    private void StartWallpaperTimerIfNeeded()
    {
        if (_wallpaperTimer != null) return;
        // Use a 1-second base tick and throttle in the handler according to the chosen interval.
        _wallpaperTimer = new Timer(1_000);
        _wallpaperTimer.Elapsed += OnWallpaperTick;
        _wallpaperTimer.AutoReset = true;
        _wallpaperTimer.Start();
    }

    private void StopWallpaperTimer()
    {
        _wallpaperTimer?.Stop();
        _wallpaperTimer?.Dispose();
        _wallpaperTimer = null;
    }

    private void OnWallpaperTick(object? sender, ElapsedEventArgs e)
    {
        if (_wallpaperIntervalSeconds == WallpaperIntervalEveryMinute)
        {
            // Minute-level granularity: only update when the minute changes.
            var currentMinute = DateTime.Now.Minute;
            if (currentMinute == _lastWallpaperMinute) return;
            _lastWallpaperMinute = currentMinute;
        }
        else
        {
            // Second-level granularity: only update when the seconds value changes to
            // avoid redundant calls within the same second.
            if (Seconds == _lastWallpaperSecond) return;
            _lastWallpaperSecond = Seconds;
        }
        InvokeAsync(SetWallpaperNow);
    }

    /// <summary>
    /// Returns the pixel dimensions to use when generating the wallpaper image.
    /// On Android we use the actual display size in portrait orientation so the
    /// wallpaper fills the screen without cropping or off-centre rendering.
    /// All other platforms keep the default 1920×1080 landscape layout.
    /// </summary>
    private static (int width, int height) GetWallpaperDimensions()
    {
#if ANDROID
        var info = DeviceDisplay.Current.MainDisplayInfo;
        int w = (int)info.Width;
        int h = (int)info.Height;
        if (w > 0 && h > 0)
        {
            // Ensure portrait orientation (taller than wide).
            if (w > h)
                (w, h) = (h, w);
            return (w, h);
        }
        // Fallback to a standard FHD portrait size when display info is unavailable.
        return (1080, 1920);
#else
        return (1920, 1080);
#endif
    }

    private Services.WallpaperData BuildWallpaperData(byte[]? imageBytes)
        => new Services.WallpaperData(
            TargetDate: _targetDate,
            TotalDays: TotalDays,
            Years: Years,
            Months: Months,
            Days: Days,
            Hours: Hours,
            Minutes: Minutes,
            Seconds: Seconds,
            CurrentTime: _currentTime,
            BackgroundImageBytes: imageBytes,
            Culture: _currentCulture);

    private async Task<byte[]?> GetCurrentImageBytes()
    {
        var src = CurrentImageSrc;
        if (string.IsNullOrEmpty(src)) return null;

        if (src.StartsWith("data:"))
        {
            // data URL — extract the base64 payload after the comma
            var commaIdx = src.IndexOf(',');
            if (commaIdx < 0) return null;
            try { return Convert.FromBase64String(src[(commaIdx + 1)..]); }
            catch (FormatException)
            {
                // Malformed base64 in the data URL — skip the image and render without it.
                return null;
            }
        }

        // MAUI asset (e.g. "images/1.jpg")
        try
        {
            await using var stream = await FileSystem.OpenAppPackageFileAsync(src);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            return ms.ToArray();
        }
        catch (Exception ex)
        {
            // Asset may not exist (e.g. custom image removed); generate wallpaper without it.
            System.Diagnostics.Debug.WriteLine($"[WallpaperGenerator] Could not load image '{src}': {ex.Message}");
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_countdownTimer != null)
        {
            _countdownTimer.Stop();
            _countdownTimer.Dispose();
        }
        StopSlideshowTimer();
        StopWallpaperTimer();
        await ValueTask.CompletedTask;
    }
}
