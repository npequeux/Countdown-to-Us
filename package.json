{
  "name": "countdown-to-us",
  "version": "1.1.0",
  "description": "A beautiful countdown timer displaying the time remaining until October 1, 2028.",
  "main": "electron/main.js",
  "scripts": {
    "sync": "npx cap sync",
    "build:android": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "build:android-release": "npx cap sync android && cd android && ./gradlew assembleRelease",
    "build:android-bundle": "npx cap sync android && cd android && ./gradlew bundleRelease",
    "open:android": "npx cap open android",
    "electron": "electron .",
    "build:win": "electron-builder --win --x64 --publish never",
    "build:linux": "electron-builder --linux --x64 --publish never",
    "build:desktop": "electron-builder --win --linux --x64 --publish never",
    "test": "echo \"Open index.html in a browser to test the web app\""
  },
  "build": {
    "appId": "com.npequeux.countdown-to-us",
    "productName": "Countdown to Us",
    "copyright": "Copyright © 2024 npequeux",
    "icon": "build/icon.png",
    "files": [
      "index.html",
      "countdown.js",
      "style.css",
      "electron/main.js",
      "build/icon.png",
      "build/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npequeux/Countdown-to-Us.git"
  },
  "keywords": [
    "countdown",
    "timer",
    "android",
    "capacitor",
    "mobile-app",
    "countdown-timer",
    "date-countdown"
  ],
  "author": {
    "name": "npequeux",
    "email": "44464592+npequeux@users.noreply.github.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/npequeux/Countdown-to-Us/issues"
  },
  "homepage": "https://github.com/npequeux/Countdown-to-Us#readme",
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
